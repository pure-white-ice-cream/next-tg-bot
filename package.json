{
	"name": "next-tg-bot",
	"description": "Build a full-stack web application with Next.js.",
	"scripts": {
		"// build": "编译 Next.js 应用，生成用于生产环境的优化产物",
		"build": "next build",

		"// cf-typegen": "为 Cloudflare 环境变量生成 TypeScript 类型定义",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv env.d.ts",

		"// check": "综合检查: 先尝试构建应用，再运行 TypeScript 编译器 (tsc)",
		"check": "npm run build && tsc",

		"// deploy": "部署到 Cloudflare: 转换为兼容格式并直接发布上线",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",

		"// dev": "启动本地开发服务器，支持热更新",
		"dev": "next dev",

		"// lint": "运行 ESLint 静态检查，修复代码质量或格式问题",
		"lint": "next lint",

		"// preview": "本地预览: 在模拟 Cloudflare 环境中构建并预览",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",

		"// start": "在本地启动生产模式服务（仅用于非 Workers 环境测试）",
		"start": "next start"
	},
	"cloudflare": {
		"label": "Next.js Framework Starter",
		"products": [
			"Workers"
		],
		"categories": [],
		"preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/05eee9e0-2c04-48fd-11bf-84e65f839000/public",
		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/4e913a56-fd99-4372-0586-9f1364173100/preview",
		"publish": true
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.14.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.564.0",
		"next": "^16.0.7",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react": "^19.2.1",
		"react-dom": "^19.2.1",
		"tailwind-merge": "^3.4.0"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4.1.17",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"eslint": "^9.39.2",
		"eslint-config-next": "^16.0.7",
		"shadcn": "^3.8.4",
		"tailwindcss": "^4.1.17",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"wrangler": "^4.56.0"
	},
	"private": true
}